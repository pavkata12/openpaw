# OpenPaw — copy to .env and fill in

# LLM: OpenAI-compatible API. Pick ONE preset below.

# --- EASIEST: OpenRouter (Kimi K2 FREE) ---
# 1. Get free API key at https://openrouter.ai/keys
# 2. Uncomment these 3 lines:
# OPENPAW_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENPAW_LLM_MODEL=moonshotai/kimi-k2:free
# OPENPAW_LLM_API_KEY=sk-or-v1-...

# --- Kimi (Moonshot AI direct) ---
# Get key at https://platform.moonshot.ai/console/api-keys
# OPENPAW_LLM_BASE_URL=https://api.moonshot.ai/v1
# OPENPAW_LLM_MODEL=moonshot-v1-32k
# OPENPAW_LLM_API_KEY=sk-...

# --- Local: Ollama (no API key) ---
OPENPAW_LLM_BASE_URL=http://localhost:11434/v1
OPENPAW_LLM_MODEL=llama3.2
OPENPAW_LLM_API_KEY=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

# --- OpenAI ---
# OPENPAW_LLM_BASE_URL=https://api.openai.com/v1
# OPENPAW_LLM_MODEL=gpt-4o-mini
# OPENPAW_LLM_API_KEY=sk-...

# Channel: discord (optional)
OPENPAW_DISCORD_TOKEN=

# Data directory (memory, config). Use absolute path when running from systemd/Docker.
OPENPAW_DATA_DIR=./.openpaw

# Optional: config directory (resolves relative paths from here)
# OPENPAW_CONFIG=/etc/openpaw

# Logging: text or json
OPENPAW_LOG_FORMAT=text

# Memory: max entries before pruning (default 1000)
# OPENPAW_MEMORY_MAX_ENTRIES=1000

# Shell: sandbox (allowlist) or full control like OpenClaw
# OPENPAW_SHELL_FULL_CONTROL=true   # no allowlist/blocklist, cwd support, cmd.exe (Windows) / bash (Linux)
# OPENPAW_SHELL_TIMEOUT=60000       # ms (default 60s when full control, 30s when sandboxed)
# Sandbox only: comma-separated allowlist (default: ls, cat, node, etc.)
# OPENPAW_SHELL_ALLOWED=ls,cat,node,npm
# OPENPAW_SHELL_BLOCKED_PATHS=/etc,/root

# Agent mode: native (tool-calling API), react (ReAct prompt), auto (native)
# OPENPAW_AGENT_MODE=auto

# Voice STT (local): Xenova/whisper-tiny.en (English only) or Xenova/whisper-tiny (multilingual, e.g. Bulgarian)
# OPENPAW_STT_MODEL=Xenova/whisper-tiny
# OPENPAW_STT_LANGUAGE=bulgarian

# History summarization (default: 20 messages trigger, keep last 10 raw)
# OPENPAW_HISTORY_SUMMARIZE_THRESHOLD=20
# OPENPAW_HISTORY_KEEP_RAW=10

# Scheduler (gateway mode): set to 0 or false to disable
# OPENPAW_SCHEDULER_ENABLED=true

# Email (optional): for email_search and email_send tools
# OPENPAW_EMAIL_HOST=imap.gmail.com
# OPENPAW_EMAIL_PORT=993
# OPENPAW_EMAIL_USER=
# OPENPAW_EMAIL_PASS=
# OPENPAW_EMAIL_SECURE=true

# Telegram (optional): bot token and comma-separated allowed user IDs
# OPENPAW_TELEGRAM_BOT_TOKEN=
# OPENPAW_TELEGRAM_ALLOWED_IDS=

# Knowledge base (RAG): directory and embedding model
# OPENPAW_KNOWLEDGE_DIR=./.openpaw/knowledge
# OPENPAW_EMBEDDING_MODEL=text-embedding-3-small

# ElevenLabs STT (optional, cloud): set provider=elevenlabs and API key/model id
# OPENPAW_STT_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_STT_MODEL_ID=scribe_v2
# ELEVENLABS_STT_LANGUAGE_CODE=bg

# Google Search (optional): enables google_search tool so the AI can search the web
# 1. Google Cloud Console: create project, enable "Custom Search API", create API key
# 2. https://programmablesearchengine.google.com/ — create search engine (search whole web), copy "Search engine ID" (cx)
# OPENPAW_GOOGLE_SEARCH_API_KEY=
# OPENPAW_GOOGLE_SEARCH_ENGINE_ID=
