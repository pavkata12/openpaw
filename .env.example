
OPENPAW_LLM_BASE_URL=https://openrouter.ai/api/v1
# Free model — изберете от: node scripts/list-models.mjs
OPENPAW_LLM_MODEL=stepfun/step-3.5-flash:free
# Get a free key at https://openrouter.ai/keys if this one is invalid
OPENPAW_LLM_API_KEY=
OPENPAW_DATA_DIR=./.openpaw

# Dual-agent: втори модел — първият може да използва delegate_to_agent и да подава подзадачи на втория (двата си говорят и споделят работата).
# OPENPAW_LLM_2_BASE_URL=https://openrouter.ai/api/v1
# OPENPAW_LLM_2_MODEL=google/gemma-2-9b-it:free
# OPENPAW_LLM_2_API_KEY=
# OPENPAW_DELEGATE_MAX_CONTEXT_EXCHANGES=5

# Voice: multilingual Whisper за български. За само английски: Xenova/whisper-tiny.en
OPENPAW_STT_MODEL=Xenova/whisper-tiny
OPENPAW_STT_LANGUAGE=bulgarian
OPENPAW_TTS_LANG=bg-BG

# ElevenLabs STT (cloud)
OPENPAW_STT_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL_ID=scribe_v2
ELEVENLABS_STT_LANGUAGE_CODE=bg

# Web search: по подразбиране се ползва DuckDuckGo (web_search) — без API, работи out of the box.
# По избор: ако попълниш долу, се добавя и google_search (за повече резултати).
OPENPAW_GOOGLE_SEARCH_API_KEY=
OPENPAW_GOOGLE_SEARCH_ENGINE_ID=

# On Kali/Linux full shell control is the default (any command). Set to false to use allowlist only.
OPENPAW_SHELL_FULL_CONTROL=true

# Root for code tools (read_file, write_file, list_dir, search_in_files, apply_patch). Default: current directory.
OPENPAW_WORKSPACE=.

# Audit: log every tool call to a file (for Kali/engagements). Default: false.
OPENPAW_AUDIT_LOG=true
 OPENPAW_AUDIT_LOG_PATH=./.openpaw/audit.log

# Directory for run_script tool (predefined scripts). Default: {OPENPAW_DATA_DIR}/scripts
OPENPAW_SCRIPTS_DIR=./.openpaw/scripts

# Danger approval: when true, run_shell commands containing OPENPAW_DANGER_PATTERNS require user to reply "approve".
# OPENPAW_DANGER_APPROVAL=true
# OPENPAW_DANGER_PATTERNS=sudo,rm -rf,nc -e,msfconsole,msfvenom

# LLM retry: on timeout or 5xx, retry this many times with exponential backoff.
 OPENPAW_LLM_RETRY_COUNT=2
 OPENPAW_LLM_RETRY_DELAY_MS=2000

# Skill pack: recon, wireless, web, or full (default). When set, only base tools + pack tools are loaded.
OPENPAW_PACK=recon

# System prompt from workspace: default = ignore; append = base + SOUL.md or .openpaw/system-prompt.md; replace = only file content.
OPENPAW_SYSTEM_PROMPT_MODE=append

# Session: TTL in hours (expired sessions not loaded/persisted); max messages per session before trim.
OPENPAW_SESSION_TTL_HOURS=24
OPENPAW_SESSION_MAX_HISTORY=50

# Optional: protect dashboard and API. When set, use ?token=... in URL or Authorization: Bearer ... or X-Dashboard-Token header.
# OPENPAW_DASHBOARD_TOKEN=your-secret-token

# Accessibility: agent acts as your hands and eyes (do anything on the computer, describe briefly). Use with voice (npm run voice or Telegram). For blind or motor-impaired users.
 OPENPAW_ACCESSIBILITY_MODE=true