{
  "name": "openpaw",
  "version": "0.1.0",
  "description": "Your self-hosted AI assistant — simpler, hackable, yours.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openpaw": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "start:cli": "node dist/cli.js chat",
    "gateway": "node dist/cli.js gateway",
    "voice": "node dist/cli.js voice",
    "dashboard": "node dist/dashboard.js",
    "start:dashboard": "node dist/dashboard.js",
    "onboard": "node dist/cli.js onboard",
    "test:voice": "node scripts/test-voice.mjs",
    "test:llm": "node scripts/test-llm.mjs"
  },
  "keywords": [
    "ai",
    "assistant",
    "self-hosted",
    "automation",
    "llm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "busboy": "^1.6.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "edge-tts-universal": "^1.4.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "imap": "^0.8.19",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.1",
    "wavefile": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/imap": "^0.8.43",
    "@types/node": "^22.9.0",
    "@types/node-fetch": "^2.6.13",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/nodemailer": "^7.0.11",
    "typescript": "^5.6.3"
  }
}
